using DesafioAPI.DataAccess;
using DesafioAPI.Dominio;
using Microsoft.EntityFrameworkCore;

namespace DesafioAPI.DataAccess.Repositorios
{
    public class JogoRepositorio
    {
        private readonly Contexto _contexto;

        public JogoRepositorio(Contexto contexto)
        {
            _contexto = contexto;
        }

        public async Task<List<Jogo>> ObterTodosAsync()
        {
            return await _contexto.Jogos.ToListAsync();
        }

        public async Task<Jogo> ObterPorIdAsync(int id)
        {
            return await _contexto.Jogos.FindAsync(id);
        }

        public async Task AdicionarAsync(Jogo jogo)
        {
            _contexto.Jogos.Add(jogo);
            await _contexto.SaveChangesAsync();
        }

        public async Task AtualizarAsync(Jogo jogo)
        {
            _contexto.Jogos.Update(jogo);
            await _contexto.SaveChangesAsync();
        }

        public async Task RemoverAsync(Jogo jogo)
        {
            _contexto.Jogos.Remove(jogo);
            await _contexto.SaveChangesAsync();
        }
    }
}
